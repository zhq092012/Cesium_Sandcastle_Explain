import * as Cesium from "cesium";

/* eslint-disable no-unused-vars */

const viewer = new Cesium.Viewer("cesiumContainer");
/**
 * 红线 (redLine)：贴地形的大圆航线
 * 数学轨迹：默认采用 大圆航线（Great Circle/Geodesic）。这是地球球面上两点之间的最短距离，在视觉上看起来会有一点向北弯曲的弧度。
 * 核心特性：clampToGround: true。这意味着这条线紧贴地面。如果你的地图开启了 3D 地形（山脉、峡谷），这条线会像一条丝带一样，随着地形的起伏而上下波动，绝对不会穿透到大山内部。
 * 材质：纯红色。
 */
const redLine = viewer.entities.add({
  name: "Red line on terrain",
  polyline: {
    positions: Cesium.Cartesian3.fromDegreesArray([-75, 35, -125, 35]),
    width: 5,
    material: Cesium.Color.RED,
    clampToGround: true,
  },
});
/**
 * 绿线 (greenRhumbLine)：贴地形的 Rhumb 航线
 * 数学轨迹：采用 Rhumb 航线（Rhumb Line）。这是一条在地球球面上的直线，不会弯曲，而是沿着南北方向平行移动。
 * 核心特性：arcType: Cesium.ArcType.RHUMB。这意味着这条线不会沿着地球表面弯曲，而是沿着南北方向平行移动。
 * 材质：纯绿色。
 */
const greenRhumbLine = viewer.entities.add({
  name: "Green rhumb line",
  polyline: {
    positions: Cesium.Cartesian3.fromDegreesArray([-75, 35, -125, 35]),
    width: 5,
    arcType: Cesium.ArcType.RHUMB,
    material: Cesium.Color.GREEN,
  },
});

const glowingLine = viewer.entities.add({
  name: "Glowing blue line on the surface",
  polyline: {
    positions: Cesium.Cartesian3.fromDegreesArray([-75, 37, -125, 37]),
    width: 10,
    material: new Cesium.PolylineGlowMaterialProperty({
      glowPower: 0.2,
      taperPower: 0.5,
      color: Cesium.Color.CORNFLOWERBLUE,
    }),
  },
});

const orangeOutlined = viewer.entities.add({
  name: "Orange line with black outline at height and following the surface",
  polyline: {
    positions: Cesium.Cartesian3.fromDegreesArrayHeights([
      -75, 39, 250000, -125, 39, 250000,
    ]),
    width: 5,
    material: new Cesium.PolylineOutlineMaterialProperty({
      color: Cesium.Color.ORANGE,
      outlineWidth: 2,
      outlineColor: Cesium.Color.BLACK,
    }),
  },
});

const purpleArrow = viewer.entities.add({
  name: "Purple straight arrow at height",
  polyline: {
    positions: Cesium.Cartesian3.fromDegreesArrayHeights([
      -75, 43, 500000, -125, 43, 500000,
    ]),
    width: 10,
    arcType: Cesium.ArcType.NONE,
    material: new Cesium.PolylineArrowMaterialProperty(Cesium.Color.PURPLE),
  },
});

const dashedLine = viewer.entities.add({
  name: "Blue dashed line",
  polyline: {
    positions: Cesium.Cartesian3.fromDegreesArrayHeights([
      -75, 45, 500000, -125, 45, 500000,
    ]),
    width: 4,
    material: new Cesium.PolylineDashMaterialProperty({
      color: Cesium.Color.CYAN,
    }),
  },
});

viewer.zoomTo(viewer.entities);
